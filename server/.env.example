# Core
NODE_ENV=development
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/localsurf

# Redis
REDIS_URL=redis://localhost:6379

# Set to true to log every SQL query (adds latency; use when debugging)
LOG_SQL=false

# CORS (comma-separated origins for multiple frontends)
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# JWT (min 32 chars — generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://s3.amazonaws.com
